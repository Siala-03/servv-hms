# Copy to .env and fill in your values
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Server
PORT=4000
# Comma-separated allowlist (no spaces) for browser origins.
# Example: http://localhost:5173,https://hms.servv.co,https://servv-hms.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── WhatsApp Business Cloud API (Meta) ──────────────────────────────────────
# Get these from: Meta Developer Console → Your App → WhatsApp → API Setup
# WHATSAPP_PHONE_NUMBER_ID  — the numeric ID of your test/production phone number
# WHATSAPP_TOKEN            — temporary (dev) or permanent system user access token
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_TOKEN=your-whatsapp-access-token

# Hotel display name used in WhatsApp messages
HOTEL_NAME=SERVV Hotel

# ── Booking.com live integration ─────────────────────────────────────────────
# Provide either BOOKING_COM_TOKEN OR BOOKING_COM_USERNAME + BOOKING_COM_PASSWORD
# BOOKING_COM_SYNC_URL should be the live endpoint assigned to your Booking.com partner account.
BOOKING_COM_HOTEL_ID=your-booking-com-hotel-id
BOOKING_COM_SYNC_URL=https://your-booking-com-live-endpoint
BOOKING_COM_TOKEN=
BOOKING_COM_USERNAME=
BOOKING_COM_PASSWORD=
